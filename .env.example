# ---- Frontend (Vercel) environment ----

# Base URL of the backend API deployed on Render.
# Local dev: http://localhost:8787
# Production: https://your-api.onrender.com
VITE_API_URL=http://localhost:8787

# Google OAuth (opcional). Mesmo Client ID que GOOGLE_CLIENT_ID no backend.
# Deixe vazio para esconder o botão "Entrar com Google".
VITE_GOOGLE_CLIENT_ID=
