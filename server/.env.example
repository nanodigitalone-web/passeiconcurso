# ---- Backend (Render) environment ----

# Postgres connection string (Render Postgres, Neon, Supabase DB, etc.)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Set to "true" when the DB requires SSL (Render/Neon usually need this).
DATABASE_SSL=true

# Secret used to sign JWT access tokens (use a long random string).
JWT_SECRET=change-me-to-a-long-random-string
# Token lifetime.
JWT_EXPIRES_IN=30d

# Comma-separated emails that are auto-granted the admin role on register/login.
ADMIN_EMAILS=nanodigitalone@gmail.com,joelarmandomanuel@gmail.com,jamanueljo@gmail.com

# Allowed CORS origins (the Vercel frontend URL). Comma-separated.
CORS_ORIGINS=http://localhost:8080,https://your-app.vercel.app

# Google OAuth (optional — needed for "Sign in with Google").
GOOGLE_CLIENT_ID=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BO7y5DEKL6n6nLquKXoTCj-Qo-2pcqrtmesZzL3qTGSsv18QGx2B0yMBwJNvqujokNQkCVDXmn_pSTkuwfpitoQ
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@passeii.com

# Secret required in the x-cron-secret header to trigger the push cron endpoint.
CRON_SECRET=

# Where uploaded payment proofs are stored on disk (mount a persistent disk on Render).
UPLOAD_DIR=./uploads

# Port (Render sets PORT automatically).
PORT=8787
